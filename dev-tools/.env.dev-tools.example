# Copie este arquivo para dev-tools/.env.dev-tools e preencha com os valores do seu projeto.
# O arquivo .env.dev-tools está no .gitignore — NUNCA o commite.

# ── setup-local.mjs e seed-emulator.js (emuladores) ─────────────────────────
# ID do projeto Firebase (Firebase Console → Project Settings → General)
FIREBASE_PROJECT_ID=your-project-id

# Portas dos emuladores — só altere se divergirem do padrão no firebase.json
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Senhas dos usuários de seed — obrigatórias para rodar scripts/seed-emulator.js
SEED_ADMIN_PASSWORD=defina-uma-senha-aqui
SEED_ALPHA_PASSWORD=defina-uma-senha-aqui
SEED_BETA_PASSWORD=defina-uma-senha-aqui

# ── bootstrap-prod.mjs (pré-prod / produção) ─────────────────────────────────
# Não usa este arquivo. Exporte o service account como variável de ambiente:
#
#   export GOOGLE_APPLICATION_CREDENTIALS=/caminho/absoluto/para/service-account.json
#
# O arquivo service-account.json já está coberto pelo .gitignore (*firebase-adminsdk*.json).
